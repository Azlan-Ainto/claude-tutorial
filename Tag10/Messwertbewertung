print("\n======= Motortemperatur-Schnelllchek ===")
# ............. Symbole ............................................
alarm = chr(0x26D4)
ok = chr(0x2705)
warn = chr(0x26A0)
# ....................................................................
for _ in range(4):
    t = rnd.uniform(60.0,115.0)
    symbol = alarm if t>100 else warn if t>85 else ok
    label = "ALARM" if t>100 else "WARM" if t > 85 else "OK"
    print(f"T={t:.1f}°C -> {symbol} {label}")
    
