import random as rnd
rnd.seed()
# ====== Widerstandsmessung - IO / NIO ========
print("\n=== Widerstandsprüfung ===\n")
soll = 100.0        # Ohm
tol = 0.05          # 5%
grenze = soll * tol
# ---- Symbole -------------------
io = chr(9989)      # ✔                  
#nio = chr(10006)    # ✖           
widerstand_io = chr(9608)   # █
widerstand_nio = chr(9618)  # ▒
delta = chr(916)
ohm = chr(937)
nio = "❌"
# --------------------------------  
for nr in range(1,7):
    messwert = rnd.uniform(93.0, 108.0)
    abweichung = abs(messwert - soll)
    urteil = f"{io} IO" if abweichung <= grenze else f"{nio} NIO"
    symbol = f"{widerstand_io}" if abweichung <= grenze else f"{widerstand_nio}"
    print(f"\nBauteil {nr}: {messwert:6.2f} {ohm} {delta:>5} {abweichung:4.2f} {symbol:>5} {urteil:>5}")
print()
