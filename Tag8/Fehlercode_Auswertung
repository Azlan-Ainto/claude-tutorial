import random
random.seed()
print("\n=== CNC-Maschine Fehlerdiagnose ===")
fehler_codes = [0,101,202,303,404, 999]
code = random.choice(fehler_codes)
print(f"Fehlercode: {code}")
match code:
    case 0:
        print(f"{chr(9989)} Kein Fehler - Maschine betriebsbereit")
    case 101:
        print(f"{chr(9888)} Achse X - Positionsfehler")
    case 202:
        print(f"{chr(9888)} Kühlmitteldruch zu niedrig")
        print(f"{chr(10145)} Maßnahme: Werkzeug wechslen")
    case 303:
        print(f"{chr(9888)} Werkzeugbruch erkannt (Sensor A/B)")
        print(f"{chr(128736)} Maßnahme: Werkzeug wechseln")
    case 404:
        print(f"{chr(9940)} Spindel-Überhitzung - Notaus")
        print(f"{chr(128736)} Maßnahme: Werkzeug wechseln. ")
    case 505:
        print(f"{chr(128736)} Schutzgiter offen - Sicherheitshalt")
        print(f"{chr(128736)} Maßnahme: Gitter schließen & quittieren")
    case _:
        print(f"{chr(10060)} Unbekannter Code {code} - Service rufen")

# ----------- Betriebsmodus Steuerung -----------------------------------
