
import random as rnd
import math
rnd.seed(11)
# ...... Temperaturkurve ..............
print()
print("\n===== Abkühlkurve eines Stahlbolzens ===\n")
print(f"{'Zeit':>8} {'Temp':>8} {'Abkühlbalken':>16}")
print("-"*44)

T_start = 850.0     # °C 
k = 0.08            # Abkühlkonstante
T_umg = 20.0        # °C Umgebungstemperatur

# ...... ANSI-Farben .......
ROT = "\033[31m"
BLAU = "\033[34m" 
RESET = "\33[0m"
#............................

for t in range(0,55,5):
    # Newtonsche Abkühlformel: T(t) = T_umg + (T_start - T_umg)* e^(-k*t)
    T = T_umg + (T_start - T_umg) * math.exp(-k*t)
    balken = f"{chr(9608)}" * int(T/50)
    print(f"{t:4} min {BLAU}{T:7.1f} C°{RESET} {ROT}{balken}{RESET}")
    print()

# ------ Akkumulatoren(Summe, Min, Max) ------
print("\n====== Temperaturmessreihe - Auswertung =====")
anzahl = 8
summe = 0.0
t_min = float("inf")        # Startwert: unendlich groß
t_max = float("-inf")       # Startwert: unendlich klein

# ..... Symbole ..........
warnung = chr(0x26A0)
ok = chr(0x2714)
# .......................
for i in range(1, anzahl + 1):
    temp = rnd.uniform(18.0, 35.0)
    summe += temp
    t_min = min(t_min, temp)
    t_max = max(t_max, temp)
    status = f"ok" if 20 <= temp <= 30 else f"warnung"
    print(f"Sensor: {i}: {temp: .2f} °C {status}")
mittelwert = summe / anzahl
print(f"\nMittelwert: {mittelwert:.2f} °C")
print(f"Minimum: {t_min:.2f} °C")
print(f"Maximum: {t_max:.2f} °C")
print(f"Spanne: {t_max - t_min: .2f} °C")

# ........ range mit Schrittweite - Widerstandsreihe .......
print("\n==== E12-Widerstandsreihe (10-100 Ohm) ====")
e12 = [10,12,15,18,22,27,33,39,47,56,68,82,100]
for r in e12:
    I = 5.0 / r
    print(f"R={r:3} ohm -> I={I*1000:6.1f} mA", end="")
print()
